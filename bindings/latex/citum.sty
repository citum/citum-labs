% citum.sty — Citum LaTeX Package for LuaLaTeX
% Integrates the Citum Rust citation processor into LuaLaTeX via LuaJIT FFI.
% Usage:
%   \usepackage[style=apa-7th, bibfile=refs]{citum}            % Citum YAML bib
%   \usepackage[style=apa-7th, bibfile=refs.bib, locale=en-US]{citum}
%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{citum}[2026/03/02 v0.2.1 Citum citation processor]

\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

\ifx\directlua\undefined
  \PackageError{citum}{citum requires LuaLaTeX}\relax
\fi

\SetupKeyvalOptions{family=citum,prefix=citum@}
\DeclareStringOption[apa-7th]{style}
\DeclareStringOption{bibfile}
\DeclareStringOption{locale}
\DeclareBoolOption{rpc}
\ProcessKeyvalOptions*

\ifcsvoid{citum@bibfile}{
  \PackageError{citum}{No bibfile specified. Use \usepackage[bibfile=...]{citum}}{}
}{}

% Path to a Citum YAML style file (without extension, resolved via kpse, or
% absolute path).
\def\citum@style{\citum@style}

% Bibliography file: Citum YAML format only (.yaml/.yml).
% Citum reads the file in Lua and passes the YAML string to the FFI
% (citum_processor_new_from_yaml / citum_processor_new_with_locale_from_yaml).
% Biblatex .bib input is not supported via the C FFI.
\def\citum@bibfile{\citum@bibfile}

% Optional locale name (e.g. en-US, fr-FR).
\def\citum@locale{\citum@locale}

\directlua{
  local function find_citum_lua()
    local env = os.getenv("CITUM_LUA_PATH")
    if env and env ~= "" then return env end
    
    local sty_path = kpse.find_file("citum.sty", "tex") or ""
    if sty_path ~= "" then
      local last_slash = sty_path:match("(.*[/\\])")
      if last_slash then
        local candidate = last_slash .. "citum.lua"
        if lfs.attributes(candidate) then return candidate end
      end
    end
    
    return kpse.find_file("citum.lua", "lua")
  end

  local citum_lua = find_citum_lua()
  if not citum_lua then
    error("citum.sty: cannot find citum.lua. "
      .. "Set CITUM_LUA_PATH or place citum.lua next to citum.sty.")
  end

  local ok, result = pcall(dofile, citum_lua)
  if not ok then
    error("citum.sty: failed to load citum.lua: " .. tostring(result))
  end
  citum_module = result
  if not citum_module then
    error("citum.sty: citum.lua returned nil. Check libcitum_processor is built.")
  end

  if citum_module then
    local style_path = kpse.find_file("\citum@style", "tex") or "\citum@style"
    local bib_path   = kpse.find_file("\citum@bibfile", "tex") or "\citum@bibfile"
    citum_proc = citum_module.init_processor(
      style_path, bib_path, "\citum@locale", "\jobname", \ifcitum@rpc true \else false \fi
    )
    
    at_end_document_hook = function()
      citum_module.process_document(citum_proc, style_path, bib_path, "\citum@locale")
    end
  end
}

\AtEndDocument{\directlua{at_end_document_hook()}}

% parse_locator, do_cite, cite_single, etc. are all in citum.lua.

\renewcommand{\cite}[2][]{%
  \directlua{citum_module.cite_single(citum_proc, 
    "\luaescapestring{#1}", "\luaescapestring{#2}")}%
}

\newcommand{\textcite}[2][]{%
  \directlua{citum_module.textcite_single(citum_proc, 
    "\luaescapestring{#1}", "\luaescapestring{#2}")}%
}

\newcommand{\cites}[1]{%
  \directlua{citum_module.cite_keys(citum_proc, "\luaescapestring{#1}")}%
}

\newcommand{\textcites}[1]{%
  \directlua{citum_module.textcite_keys(citum_proc, "\luaescapestring{#1}")}%
}

\newcommand{\citestart}{%
  \directlua{citum_module.cites_start()}%
}

\newcommand{\citeitem}[2][]{%
  \directlua{citum_module.cites_add(
    "\luaescapestring{#1}", "\luaescapestring{#2}")}%
}

\newcommand{\citeend}{%
  \directlua{citum_module.cites_flush(citum_proc)}%
}

\newcommand{\textciteend}{%
  \directlua{citum_module.cites_flush_integral(citum_proc)}%
}

% Switch style or bib file at runtime
\newcommand{\citumsetup}[1]{%
  \setkeys{citum}{#1}%
  \directlua{
    local style_path = kpse.find_file("\citum@style", "tex") or "\citum@style"
    local bib_path   = kpse.find_file("\citum@bibfile", "tex") or "\citum@bibfile"
    citum_proc = citum_module.init_processor(
      style_path, bib_path, "\citum@locale", "\jobname", \ifcitum@rpc true \else false \fi
    )
  }%
}

\newcommand{\printcitumbibliography}{%
  \directlua{citum_module.print_bibliography(citum_proc)}%
}

\providecommand{\printbibliography}{\printcitumbibliography}

\endinput
